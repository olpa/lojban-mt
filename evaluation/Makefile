tok-en:
	python3 tokenize.py --dataset copy-of-corpus.xx --src-field en --tgt-field en-moses-tok --tokenizer moses-en --output tokenized.only-en.xx

trans100en2jb:
	python3 translate-with-moses.py --dataset olpa/jbo-corpus --endpoint localhost:1234 --src-field en --tgt-field jb-moses --output translated-1.0.0.xx
